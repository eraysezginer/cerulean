# Copy to .env and adjust.

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MySQL — create the database and apply `db/schema.sql`
# For existing DBs, also run `db/migrations/001_document_ingest_ai_analysis.sql`
# mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL="mysql://root:password@127.0.0.1:3306/cerulean"

# OpenRouter (server-only) — required for upload "Generate flags and analysis"
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: defaults to a small model if unset
# OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Optional: cap payload when sending files to the model (bytes)
# INGEST_AI_MAX_FILE_BYTES=12582912
# INGEST_AI_TOTAL_FILE_BYTES=25165824
