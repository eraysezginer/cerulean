# Copy to .env and adjust.

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# mysql2 — MySQL’de veritabanı oluşturup `db/schema.sql` çalıştırın
# Eski veritabanı: AI analiz kalıcılığı için ayrıca `db/migrations/001_document_ingest_ai_analysis.sql` uygulayın
# mysql://KULLANICI:PAROLA@HOST:3306/VERITABANI
DATABASE_URL="mysql://root:parola@127.0.0.1:3306/cerulean"

# İsteğe bağlı: dosyayı modele gönderirken toplam/başına bayt sınırı (OpenRouter yükü)
# INGEST_AI_MAX_FILE_BYTES=12582912
# INGEST_AI_TOTAL_FILE_BYTES=25165824
