# =============================================================================
# Cerulean — ortam değişkenleri (şablon)
# Kopyalayın: cp .env.example .env
# Ardından .env içindeki boş alanları doldurun.
# =============================================================================

# --- Uygulama ---
# development | production | test
NODE_ENV=development

# Tarayıcıda kullanılacak tam kök adres (ör. https://cerulean.example.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Sunucu / DigitalOcean (referans — kodda kullanmıyorsanız yorumda kalabilir) ---
# Droplet genel IPv4 veya domain
# DROPLET_IP=
# DOMAIN=
# SSH kullanıcı adı (ör. deploy) — not amaçlı; uygulama okumaz
# DEPLOY_USER=

# --- Next.js (production’da genelde reverse proxy portunu dinler) ---
# Örnek: sunucuda PM2/systemd ile 3000 kullanıyorsanız değiştirmeyin
# PORT=3000
# HOSTNAME=0.0.0.0

# --- İleride: kimlik doğrulama / API ---
# NEXTAUTH_URL=https://your-domain.com
# NEXTAUTH_SECRET=
# API_KEY_EXTERNAL=

# --- İleride: veritabanı ---
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
